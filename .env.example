# Radar userbot — its own Telegram account (separate from the main collector).
# api_id / api_hash come from https://my.telegram.org; phone is the radar account.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Radar bot — a dedicated bot token from @BotFather (must differ from the main bot:
# one token cannot be polled by two processes). Alerts are delivered to TELEGRAM_ADMIN_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# Database
DATABASE_PATH=data/radar.db

# Daily verify-job timezone
RADAR_TIMEZONE=Europe/Berlin
