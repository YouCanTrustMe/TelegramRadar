# Radar userbot — its own Telegram account (separate from the main collector).
# api_id / api_hash come from https://my.telegram.org; phone is the radar account.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Radar bot — a dedicated bot token from @BotFather (must differ from the main bot:
# one token cannot be polled by two processes). Alerts are delivered to TELEGRAM_ADMIN_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# Database
DATABASE_PATH=data/radar.db

# Daily verify-job timezone
RADAR_TIMEZONE=Europe/Berlin

# Weekly silent digest of muted matches (cron day-of-week + hour, local time)
RADAR_DIGEST_DAY=mon
RADAR_DIGEST_HOUR=9

# Keyword matching. Fuzzy catches typos and inflections but cannot tell a typo
# from a real word one edit away — set it false if alerts get noisy.
RADAR_MATCH_LEET=true
RADAR_MATCH_FUZZY=true
RADAR_MATCH_TRANSLIT=true
# Keywords at least this long may also match inside a word.
RADAR_MATCH_MERGE_MIN_LEN=5
